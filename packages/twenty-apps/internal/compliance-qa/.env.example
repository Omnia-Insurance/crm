# Twenty API connection (set automatically when running via `twenty app:dev`)
TWENTY_API_URL=http://localhost:3000
TWENTY_API_KEY=

# Deepgram transcription (key must belong to the BAA-covered Enterprise project)
DEEPGRAM_API_KEY=

# AWS-backed storage, translation, and scoring
AWS_REGION=us-east-1
COMPLIANCE_QA_TRANSCRIBE_BUCKET=
COMPLIANCE_QA_TRANSCRIBE_INPUT_PREFIX=compliance-qa/input
COMPLIANCE_QA_TRANSCRIBE_OUTPUT_PREFIX=compliance-qa/output
COMPLIANCE_QA_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
COMPLIANCE_QA_MIN_DURATION_SECONDS=300
COMPLIANCE_QA_ENABLED_AFTER=
COMPLIANCE_QA_ALLOWED_DIRECTIONS=
COMPLIANCE_QA_ALLOWED_STATUSES=
COMPLIANCE_QA_ALLOWED_STATUS_NAMES=
COMPLIANCE_QA_ALLOWED_QUEUE_NAMES=
COMPLIANCE_QA_ALLOWED_LEAD_SOURCE_IDS=
COMPLIANCE_DEFAULT_MANAGER_WORKSPACE_MEMBER_ID=

# Optional for local development. Prefer AWS_PROFILE or an IAM role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
